# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
BASE_PATH=/dashboard/

# ── API proxy (local dev only — Replit handles this automatically) ─────────────
# Port your API server runs on locally (pnpm --filter @workspace/api-server run dev)
API_SERVER_PORT=8080

# ── API base URL ───────────────────────────────────────────────────────────────
# Leave blank for local dev (Vite proxy handles it).
# On Vercel set this to your deployed API server URL, e.g:
# VITE_API_BASE_URL=https://your-api.up.railway.app/api/nexis

# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get this from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
