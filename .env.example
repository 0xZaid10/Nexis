# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── 0G Storage ────────────────────────────────────────────────
ZG_PRIVATE_KEY=
ZG_EVM_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# ── Gensyn AXL ────────────────────────────────────────────────
AXL_HOST=127.0.0.1
AXL_PORT=8080
AXL_BINARY_PATH=./axl-node/axl

# ── x402 Payments ─────────────────────────────────────────────
X402_WALLET_PRIVATE_KEY=
X402_RPC_URL=https://mainnet.base.org

# ── ENS / Identity ────────────────────────────────────────────
ENS_RPC_URL=https://eth.llamarpc.com

# ── KeeperHub ─────────────────────────────────────────────────
KEEPERHUB_API_KEY=
KEEPERHUB_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── SQLite (local cache) ──────────────────────────────────────
SQLITE_PATH=./.nexis/memory.db
